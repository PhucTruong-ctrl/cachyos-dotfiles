// Zellij config — catppuccin mocha, compact layout, Alt-based navigation
// Docs: https://zellij.dev/documentation/configuration

keybinds clear-defaults=true {
    // Alt-based pane navigation (no prefix key needed)
    normal {
        bind "Alt h" { MoveFocus "Left"; }
        bind "Alt l" { MoveFocus "Right"; }
        bind "Alt j" { MoveFocus "Down"; }
        bind "Alt k" { MoveFocus "Up"; }

        // Pane management
        bind "Alt d" { NewPane "Right"; }
        bind "Alt Shift d" { NewPane "Down"; }
        bind "Alt w" { CloseFocus; }
        bind "Alt f" { ToggleFocusFullscreen; }
        bind "Alt z" { TogglePaneFrames; }

        // Tab management
        bind "Alt t" { NewTab; }
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
        bind "Alt [" { GoToPreviousTab; }
        bind "Alt ]" { GoToNextTab; }

        // Resize
        bind "Alt =" { Resize "Increase"; }
        bind "Alt -" { Resize "Decrease"; }

        // Scrollback
        bind "Alt s" { SwitchToMode "Scroll"; }

        // Session
        bind "Alt o" { SwitchToMode "Session"; }

        // Tmux mode (for muscle memory)
        bind "Ctrl b" { SwitchToMode "Tmux"; }
    }

    scroll {
        bind "j" "Down" { ScrollDown; }
        bind "k" "Up" { ScrollUp; }
        bind "d" { HalfPageScrollDown; }
        bind "u" { HalfPageScrollUp; }
        bind "Escape" "q" { SwitchToMode "Normal"; }
    }

    session {
        bind "d" { Detach; }
        bind "Escape" "q" { SwitchToMode "Normal"; }
    }

    tmux {
        bind "\"" { NewPane "Down"; SwitchToMode "Normal"; }
        bind "%" { NewPane "Right"; SwitchToMode "Normal"; }
        bind "x" { CloseFocus; SwitchToMode "Normal"; }
        bind "z" { ToggleFocusFullscreen; SwitchToMode "Normal"; }
        bind "c" { NewTab; SwitchToMode "Normal"; }
        bind "," { SwitchToMode "RenameTab"; }
        bind "p" { GoToPreviousTab; SwitchToMode "Normal"; }
        bind "n" { GoToNextTab; SwitchToMode "Normal"; }
        bind "h" { MoveFocus "Left"; SwitchToMode "Normal"; }
        bind "l" { MoveFocus "Right"; SwitchToMode "Normal"; }
        bind "j" { MoveFocus "Down"; SwitchToMode "Normal"; }
        bind "k" { MoveFocus "Up"; SwitchToMode "Normal"; }
        bind "d" { Detach; }
        bind "Escape" { SwitchToMode "Normal"; }
    }

    renametab {
        bind "Escape" { UndoRenameTab; SwitchToMode "Normal"; }
    }
}

// Compact UI — no wasted space
simplified_ui true
pane_frames false
default_layout "compact"

// Session serialization — survive crashes
session_serialization true
serialize_pane_viewport true

// Catppuccin Mocha theme
theme "catppuccin-mocha"

// Scrollback
scroll_buffer_size 10000

// Mouse support
mouse_mode true

// Copy on select
copy_on_select true
